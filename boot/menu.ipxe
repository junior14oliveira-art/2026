#!ipxe
# PXEGEMINI Boot Menu - Generated dynamically
# Server: 192.168.0.21

:start
menu PXEGEMINI - Network Boot
item WinPEBasicEnhanced WinPEBasicEnhanced.iso [uefi]
item strelec strelec [wimboot]
item exit Reboot
choose target && goto ${target}

:WinPEBasicEnhanced
# Boot UEFI: WinPEBasicEnhanced.iso
chain http://192.168.0.21/WinPEBasicEnhanced/bootx64.efi

:strelec
# Boot WinPE: strelec
kernel http://192.168.0.21/strelec/wimboot rawbcd
initrd http://192.168.0.21/strelec/bootmgr bootmgr
initrd http://192.168.0.21/strelec/bootmgr bootmgr.efi
initrd http://192.168.0.21/strelec/bootx64.efi bootmgfw.efi
initrd http://192.168.0.21/strelec/bootx64.efi EFI/Microsoft/Boot/bootmgfw.efi
initrd http://192.168.0.21/strelec/BCD BCD
initrd http://192.168.0.21/strelec/BCD boot/BCD
initrd http://192.168.0.21/strelec/boot.sdi boot.sdi
initrd http://192.168.0.21/strelec/boot.sdi boot/boot.sdi
initrd http://192.168.0.21/strelec/boot.wim boot.wim
initrd http://192.168.0.21/strelec/boot.wim sources/boot.wim
initrd http://192.168.0.21/strelec/Fonts/segmono_boot.ttf Fonts/segmono_boot.ttf
initrd http://192.168.0.21/strelec/Fonts/segmono_boot.ttf EFI/Microsoft/Boot/Fonts/segmono_boot.ttf
initrd http://192.168.0.21/strelec/Fonts/segoe_slboot.ttf Fonts/segoe_slboot.ttf
initrd http://192.168.0.21/strelec/Fonts/segoe_slboot.ttf EFI/Microsoft/Boot/Fonts/segoe_slboot.ttf
initrd http://192.168.0.21/strelec/Fonts/wgl4_boot.ttf Fonts/wgl4_boot.ttf
initrd http://192.168.0.21/strelec/Fonts/wgl4_boot.ttf EFI/Microsoft/Boot/Fonts/wgl4_boot.ttf
initrd http://192.168.0.21/strelec/SSTR/CAMINHO_IMG_REDE.bat SSTR/CAMINHO_IMG_REDE.bat
boot


:exit
reboot
