#!ipxe
# PXEGEMINI Boot Menu - GEMINIISO
# Server: 192.168.0.21

:start
menu PXEGEMINI - Network Boot (UEFI)
set menu-timeout 5000
set submenu-timeout 0

item GEMINIISO GEMINIISO WinPE [wimboot]
item exit Reboot
choose --default GEMINIISO --timeout 5000 target && goto ${target} || goto GEMINIISO

:GEMINIISO
# Boot WinPE: GEMINIISO (Strelec)
kernel http://192.168.0.21/geminiiso/wimboot rawbcd
initrd http://192.168.0.21/geminiiso/bootmgr bootmgr
initrd http://192.168.0.21/geminiiso/bootmgr bootmgr.efi
initrd http://192.168.0.21/geminiiso/bootx64.efi bootmgfw.efi
initrd http://192.168.0.21/geminiiso/bootx64.efi EFI/Microsoft/Boot/bootmgfw.efi
initrd http://192.168.0.21/geminiiso/BCD BCD
initrd http://192.168.0.21/geminiiso/BCD boot/BCD
initrd http://192.168.0.21/geminiiso/boot.sdi boot.sdi
initrd http://192.168.0.21/geminiiso/boot.sdi boot/boot.sdi
initrd http://192.168.0.21/geminiiso/boot.wim boot.wim
initrd http://192.168.0.21/geminiiso/boot.wim sources/boot.wim
initrd http://192.168.0.21/geminiiso/Fonts/segmono_boot.ttf Fonts/segmono_boot.ttf
initrd http://192.168.0.21/geminiiso/Fonts/segmono_boot.ttf EFI/Microsoft/Boot/Fonts/segmono_boot.ttf
initrd http://192.168.0.21/geminiiso/Fonts/segoe_slboot.ttf Fonts/segoe_slboot.ttf
initrd http://192.168.0.21/geminiiso/Fonts/segoe_slboot.ttf EFI/Microsoft/Boot/Fonts/segoe_slboot.ttf
initrd http://192.168.0.21/geminiiso/Fonts/wgl4_boot.ttf Fonts/wgl4_boot.ttf
initrd http://192.168.0.21/geminiiso/Fonts/wgl4_boot.ttf EFI/Microsoft/Boot/Fonts/wgl4_boot.ttf
initrd http://192.168.0.21/geminiiso/httpdisk.sys httpdisk.sys
initrd http://192.168.0.21/geminiiso/httpdisk.exe httpdisk.exe
initrd http://192.168.0.21/geminiiso/startnet.cmd startnet.cmd
initrd http://192.168.0.21/geminiiso/startnet.cmd Windows/System32/startnet.cmd
initrd http://192.168.0.21/geminiiso/SSTR/CAMINHO_IMG_REDE.bat SSTR/CAMINHO_IMG_REDE.bat
initrd http://192.168.0.21/geminiiso/Acesso_Rede_Imagem.bat Acesso_Rede_Imagem.bat
boot

:exit
reboot
